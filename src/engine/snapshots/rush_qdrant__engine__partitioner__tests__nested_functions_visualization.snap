// Test case: Nested functions inside a generator
// This pattern is common in parser code where helper functions are nested inside
// the main parsing function to share closure state.

export interface IResult {
  type: 'a' | 'b' | 'c' | 'd' | 'e' | 'f';
  value: string;
  metadata?: Record<string, string>;
}

export interface IParseContext {
  input: string;
  pos: number;
  line: number;
  column: number;
}

export type ResultHandler = (result: IResult) => void;

/**
 * A generator function with nested helper functions.
 * The nested functions should be recognized as meaningful split points.
 * This is a larger version designed to exceed the chunk size threshold.
 */
export function* parseItems(input: string): Iterable<IResult> {
  let pos: number = 0;
  let line: number = 1;
  let column: number = 1;

  function advance(delimiter: string): string {
    const newPos = input.indexOf(delimiter, pos);
    if (newPos === -1) {
      throw new Error(`Unexpected end at position ${pos} (line ${line}, column ${column})`);
    }
    const field = input.substring(pos, newPos);
    // Update line/column tracking
    for (const ch of field) {
      if (ch === '\n') {
        line += 1;
        column = 1;
      } else {
        column += 1;
      }
    }
    pos = newPos + delimiter.length;
    return field;
  }

  function parseMetadata(): Record<string, string> {
    const metadata: Record<string, string> = {};
    const count = parseInt(advance(':'), 10);
    for (let i = 0; i < count; i++) {
      const key = advance('=');
      const value = advance('\n');
      metadata[key] = value;
    }
    return metadata;
  }

  /**
   * Parse a type 'a' item.
   * This is a simple item with just a value.
   * Example: "a:value\n"
   */
  function parseA(): IResult {
    const value = advance('\n');
    return { type: 'a', value };
  }

  /**
   * Parse a type 'b' item.
   * This item includes optional metadata.
   * Example: "b:value:2:key1=val1\nkey2=val2\n"
   */
  function parseB(): IResult {
    const value = advance(':');
    const hasMetadata = input[pos] === ':';
    let metadata: Record<string, string> | undefined;
    if (hasMetadata) {
      pos += 1; // skip the colon
      metadata = parseMetadata();
    } else {
      advance('\n');
    }
    return { type: 'b', value, metadata };
  }

  /**
   * Parse a type 'c' item.
   * This is a complex item with nested structure.
   * Example: "c:value:nested\n"
   */
  function parseC(): IResult {
    const value = advance(':');
    const nested = advance('\n');
    return { type: 'c', value, metadata: { nested } };
  }

  /**
   * Parse a type 'd' item.
   * This item has multiple fields.
   * Example: "d:field1:field2:field3\n"
   */
  function parseD(): IResult {
    const field1 = advance(':');
    const field2 = advance(':');
    const field3 = advance('\n');
    return { 
      type: 'd', 
      value: field1, 
      metadata: { 
        field2, 
        field3 
      } 
    };
  }

  /**
   * Parse a type 'e' item.
   * This item includes a count and multiple values.
   * Example: "e:3:val1:val2:val3\n"
   */
  function parseE(): IResult {
    const count = parseInt(advance(':'), 10);
    const values: string[] = [];
    for (let i = 0; i < count; i++) {
      if (i < count - 1) {
        values.push(advance(':'));
      } else {
        values.push(advance('\n'));
      }
    }
    return { 
      type: 'e', 
      value: values[0], 
      metadata: { 
        count: String(count),
        allValues: values.join(',') 
      } 
    };
  }

  /**
   * Parse a type 'f' item.
   * This is the most complex item with all features.
   * Example: "f:value:2:key1=val1\nkey2=val2\n"
   */
  function parseF(): IResult {
    const value = advance(':');
    const metadata = parseMetadata();
    return { type: 'f', value, metadata };
  }

  // Main parsing loop
  while (pos < input.length) {
    const typeChar = advance(':');
    switch (typeChar) {
      case 'a':
        yield parseA();
        break;
      case 'b':
        yield parseB();
        break;
      case 'c':
        yield parseC();
        break;
      case 'd':
        yield parseD();
        break;
      case 'e':
        yield parseE();
        break;
      case 'f':
        yield parseF();
        break;
      default:
        throw new Error(`Unknown type '${typeChar}' at line ${line}, column ${column}`);
    }
  }
}
