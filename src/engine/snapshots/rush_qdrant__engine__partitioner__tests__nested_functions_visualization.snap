/**
 * A non-generator function with nested functions.
 * Tests that nested functions are also split points in regular functions.
 */
export function processItems(input: string, handler: ResultHandler): void {
  let pos: number = 0;

  function advance(delimiter: string): string {
    const newPos = input.indexOf(delimiter, pos);
    if (newPos === -1) {
      throw new Error(`Unexpected end at position ${pos}`);
    }
    const field = input.substring(pos, newPos);
    pos = newPos + delimiter.length;
    return field;
  }

  /**
   * Process a simple item.
   */
  function processSimple(): void {
    const value = advance('\n');
    handler({ type: 'a', value });
  }

  /**
   * Process a complex item with metadata.
   */
  function processComplex(): void {
    const value = advance(':');
    const hasMetadata = input[pos] === ':';
    let metadata: Record<string, string> | undefined;
    if (hasMetadata) {
      pos += 1;
      const count = parseInt(advance(':'), 10);
      metadata = {};
      for (let i = 0; i < count; i++) {
        const key = advance('=');
        const val = advance(i < count - 1 ? ':' : '\n');
        metadata[key] = val;
      }
    } else {
      advance('\n');
    }
    handler({ type: 'b', value, metadata });
  }

  /**
   * Process a batch of items.
   */
  function processBatch(): void {
    const count = parseInt(advance('\n'), 10);
    for (let i = 0; i < count; i++) {
      const typeChar = advance(':');
      switch (typeChar) {
        case 'a':
          processSimple();
          break;
        case 'b':
          processComplex();
          break;
        default:
          throw new Error(`Unknown type: ${typeChar}`);
      }
    }
  }

  while (pos < input.length) {
    const command = advance(':');
    switch (command) {
      case 'item':
        processSimple();
        break;
      case 'complex':
        processComplex();
        break;
      case 'batch':
        processBatch();
        break;
      default:
        throw new Error(`Unknown command: ${command}`);
    }
  }
}
